# Source: https://stackoverflow.com/a/33245306/31298396
sub rewrite_file {
    my $file = shift;

    # You can still read from $in after the unlink, the underlying
    # data in $file will remain until the filehandle is closed.
    # The unlink ensures $in and $out will point at different data.
    open(my $in, "<", $file);
    unlink($file);

    # This creates a new file with the same name but points at
    # different data.
    open(my $out, ">", $file);

    return($in, $out);
}

# Regex replace the characters of "$TeXname" to their LaTeX counterparts.
sub TeX_escape {
    my $args = scalar(@_);
    if ($args == 1)
    {
        my ($string) = @_;
        # To replace all backslashes '\' with '{\\textbackslash}' without conflicting with the replacement of curly braces:
            # 1. First replace '\' with '/\textbackslash/'. 
            # 2. Then replace '/\textbackslash/' with '{\textbackslash}', after the replacement of curly braces.  
            # Note: Since forward slashes '/' are guaranteed to not be in basename($path), we can be sure that '/\textbackslash/' is not a substring of basename($path). So, no substring of basename($path) should be erroneously replaced. 
        $string =~ s/\\/\/\\textbackslash\//g;
        $string =~ s/\{/\\{/g;
        $string =~ s/\}/\\}/g;
        $string =~ s/\/\\textbackslash\//{\\textbackslash}/g;
        $string =~ s/\$/\\\$/g;
        $string =~ s/&/\\&/g;
        $string =~ s/\#/\\#/g;
        $string =~ s/_/\\_/g;
        $string =~ s/%/\\%/g;
        $string =~ s/\+/\\(+\\)/g;
        $string =~ s/=/\\(=\\)/g;
        $string =~ s/ /{\\TeXtreeSpaceChar}/g;
        $string =~ s/\|/{\\textbar}/g;
        $string =~ s/</{\\textlangle}/g;
        $string =~ s/>/{\\textrangle}/g;
        $string =~ s/\^/{\\textasciicircum}/g;
        $string =~ s/~/\\textasciitilde/g;
        return($string);
    }else
    {
        die("TeX_escape: there are $args != 1 arguments passed to me.")
    }
}

sub path_to_TeXname {
    my $args = scalar(@_);
    if ($args == 1)
    {
        my ($path) = @_;
        my $TeXname = TeX_escape(basename($path));
        
        return($TeXname);
    }else
    {
        die("path_to_TeXname: there are $args != 1 arguments passed to me.")
    }
}

sub TeX_stat_core {
    my $args = scalar(@_);
    if ($args == 2)
    {
        if ($encyclopedic_opts)
        {
            my ($path, $stat_variant) = @_;
            my %stat_variants = (
                'stat'  => sub { stat($_[0]) },
                'lstat' => sub { lstat($_[0]) }
            );
            my @stat = $stat_variants{$stat_variant}($path);
            my $TeX_stat_string;
            my %stat = (
                'dev'       => $stat[0],
                'ino'       => $stat[1],
                'mode'      => $stat[2],
                'nlink'     => $stat[3],
                'uid'       => $stat[4],
                'gid'       => $stat[5],
                'rdev'      => $stat[6],
                'size'      => $stat[7],
                'atime'     => $stat[8],
                'mtime'     => $stat[9],
                'ctime'     => $stat[10],
                'blksize'   => $stat[11],
                'blocks'    => $stat[12]
            );
            $stat{'perms'} = sprintf("%04o", $stat{'mode'} & 07777);
            for (keys %stat){
                $TeX_stat_string .= "$_={$stat{$_}}, ";
            }
            return($TeX_stat_string);
        }else { return ""; }
    }else
    {
        die("TeX_stat_core: there are $args != 2 arguments passed to me.")
    }
}

sub TeX_stat {
    my $args = scalar(@_);
    if ($args == 1)
    {
        my ($path) = @_;
        return(TeX_stat_core($path, "stat"))
    }else
    {
        die("TeX_stat: there are $args != 1 arguments passed to me.")
    }
}

sub TeX_lstat {
    my $args = scalar(@_);
    if ($args == 1)
    {
        my ($path) = @_;
        return(TeX_stat_core($path, "lstat"))
    }else
    {
        die("TeX_lstat: there are $args != 1 arguments passed to me.")
    }
}

