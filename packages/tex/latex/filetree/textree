# Source: https://stackoverflow.com/a/33245306/31298396
sub rewrite_file {
    my $file = shift;

    # You can still read from $in after the unlink, the underlying
    # data in $file will remain until the filehandle is closed.
    # The unlink ensures $in and $out will point at different data.
    open(my $in, "<", $file);
    unlink($file);

    # This creates a new file with the same name but points at
    # different data.
    open(my $out, ">", $file);

    return($in, $out);
}

sub abs_path_allow_trailing_symlink {
    my $args = scalar(@_);
    if ($args == 1)
    {
        my ($path) = @_;
        my ($volume, $parent_dir, $basename) = File::Spec->splitpath( $path, 0 );
        my $parent_abs = Cwd::abs_path($parent_dir);
        return(File::Spec->catpath( $volume, $parent_abs, $basename ))
    }else
    {
        die("abs_path_allow_trailing_symlink: there are $args != 1 arguments passed to me.")
    }
} 

# Regex replace the characters of "$TeXname" to their LaTeX counterparts.
sub TeX_escape {
    my $args = scalar(@_);
    if ($args == 1)
    {
        my ($string) = @_;
        # To replace all backslashes '\' with '{\\textbackslash}' without conflicting with the replacement of curly braces:
            # 1. First replace '\' with '/\textbackslash/'. 
            # 2. Then replace '/\textbackslash/' with '{\textbackslash}', after the replacement of curly braces.  
            # Note: Since forward slashes '/' are guaranteed to not be in basename($path), we can be sure that '/\textbackslash/' is not a substring of basename($path). So, no substring of basename($path) should be erroneously replaced. 
        $string =~ s/\\/\/\\textbackslash\//g;
        $string =~ s/\{/\\{/g;
        $string =~ s/\}/\\}/g;
        $string =~ s/\/\\textbackslash\//{\\textbackslash}/g;
        $string =~ s/\$/\\\$/g;
        $string =~ s/&/\\&/g;
        $string =~ s/\#/\\#/g;
        $string =~ s/_/\\_/g;
        $string =~ s/%/\\%/g;
        $string =~ s/\+/\\(+\\)/g;
        $string =~ s/=/\\(=\\)/g;
        $string =~ s/ /{\\TeXtreeSpaceChar}/g;
        $string =~ s/\|/{\\textbar}/g;
        $string =~ s/</{\\textlangle}/g;
        $string =~ s/>/{\\textrangle}/g;
        $string =~ s/\^/{\\textasciicircum}/g;
        $string =~ s/~/\\textasciitilde/g;
        return($string);
    }else
    {
        die("TeX_escape: there are $args != 1 arguments passed to me.")
    }
}

sub path_to_TeXname {
    my $args = scalar(@_);
    if ($args == 1)
    {
        my ($path) = @_;
        my $textree_target_unslashed = $textree_target;
        if ( $textree_target =~ m/(.*)\/$/ ) { $textree_target_unslashed = $1; print("$textree_target_unslashed\n"); }
        my $TeXname;
        my $rel_path; # path of $path, relative to $textree_target.
        if ( ! defined($name_opts) )
        { $TeXname = TeX_escape(basename($path)) } # default (without the --name flag)
        # Below: if ( grep( /^$name_opts$/, @array ) ): check whether $name_opts is an element of @array
            # Source: https://stackoverflow.com/a/6475315/31298396
        elsif ( grep( /^$name_opts$/, ("tree -f","f","-f") ) )
        { $TeXname = TeX_escape($path) }
        elsif ( $path =~ m/${textree_target_unslashed}(.*)/ )
        {
            $rel_path = $1;
            # If $rel_path is not identical to "$textree_target", it has the exact form "$textree_target/...". Make $rel_path into the form ./...
            if ( $rel_path =~ m/\/(.*)/ )
            { $rel_path = "." . "$rel_path" }
            if ( grep( /^$name_opts$/, ("r","rel","relative","rel-path","rel-paths","relative-path","relative-paths") ) )
            {
                if ($path eq $textree_target)
                {
                    $TeXname = TeX_escape($textree_target)
                }else
                { $TeXname = TeX_escape($rel_path) }
            }
            elsif ( grep( /^$name_opts$/, ("a","abs","absolute","abs-path","abs-paths","absolute-path","absolute-paths") ) )
            {
                $TeXname = TeX_escape(abs_path_allow_trailing_symlink($path))
                # $TeXname = TeX_escape(File::Spec->rel2abs( $rel_path, $textree_target ))
            }else { die("path_to_TeXname: the value of \$name_opts is not recognised.") }
        }
        else { die("path_to_TeXname: the \$path = \'$path\' is not of the form" . ' \'m/${textree_target}(.*)/\'' . ' = ' . "\'$textree_target(...)\'") } # if regex did not match, which should never be the case since we used the '-f' flag of the tree command.
        return($TeXname)
    }else
    {
        die("path_to_TeXname: there are $args != 1 arguments passed to me.")
    }
}

sub TeX_stat_core {
    my $args = scalar(@_);
    if ($args == 2)
    {
        if ($encyclopedic_opts)
        {
            my ($path, $stat_variant) = @_;
            my %stat_variants = (
                'stat'  => sub { stat($_[0]) },
                'lstat' => sub { lstat($_[0]) }
            );
            my @stat = $stat_variants{$stat_variant}($path);
            my $TeX_stat_string;
            my %stat = (
                'dev'       => $stat[0],
                'ino'       => $stat[1],
                'mode'      => $stat[2],
                'nlink'     => $stat[3],
                'uid'       => $stat[4],
                'gid'       => $stat[5],
                'rdev'      => $stat[6],
                'size'      => $stat[7],
                'atime'     => $stat[8],
                'mtime'     => $stat[9],
                'ctime'     => $stat[10],
                'blksize'   => $stat[11],
                'blocks'    => $stat[12]
            );
            $stat{'perms'} = sprintf("%04o", $stat{'mode'} & 07777);
            for (keys %stat){
                $TeX_stat_string .= "$_={$stat{$_}}, ";
            }
            return($TeX_stat_string);
        }else { return ""; }
    }else
    {
        die("TeX_stat_core: there are $args != 2 arguments passed to me.")
    }
}

sub TeX_stat {
    my $args = scalar(@_);
    if ($args == 1)
    {
        my ($path) = @_;
        return(TeX_stat_core($path, "stat"))
    }else
    {
        die("TeX_stat: there are $args != 1 arguments passed to me.")
    }
}

sub TeX_lstat {
    my $args = scalar(@_);
    if ($args == 1)
    {
        my ($path) = @_;
        return(TeX_stat_core($path, "lstat"))
    }else
    {
        die("TeX_lstat: there are $args != 1 arguments passed to me.")
    }
}

# Note: since we're relying on Steve Baker's tree command, we can assume that our OS is UNIX-based. So, we need not care about volume, nor the Windows shennanigans of special relative paths of the form "C:foo/bar".
sub link_destination {
    my $args = scalar(@_);
    if ($args == 1)
    {
        my ($link) = @_;
        if (-l $link)
        {
            my $link_target = readlink($link);
            my ($volume, $parent_dir, $basename) = File::Spec->splitpath( $link, 0 );
            # Absolute path? No worries! rel2abs(abs_path) = canonpath(abs_path).
            return( File::Spec->rel2abs( $link_target, $parent_dir ) )
        }else
        { die("link_target_path: the path passed to me does not point to a symlink.") }
    }else
    { die("link_target_path: there are $args != 1 arguments passed to me.")}
}

# lstat the target of a symlink iteratively
    # Output: the TeX clist {{TeX_lstat{target_1}}},{TeX_lsat{target_2}},...}
    # There might be a trailing ", circular-link" or ", rlstat_maxed". 
sub TeX_recurse_lstat_ignore_first {
    # "ignore_first" as in the symlink itself is not lstat'ed
    if ($encyclopedic_opts)
    {
        my $args = scalar(@_);
        if ($args == 1)
        {
            my ($path) = @_;
            if (-l $path)
            {
                my $TeX_lstat;
                my $target_TeX_path;
                my $target_TeX_basename;
                my $link_is_circular;
                my $rlstat_max_reached;
                my @link_targets_that_are_a_link;
                my $target_path = link_destination($path);
                # my %target_TeX_path = (
                #     'verb' => TeX_escape($target_path),  # no processing of the path is done; the path is TeX escaped and that's it.
                #     'rel'  =>  # path relative to $textree_target
                # );
                my @TeX_lstat;
                while (
                    !$link_is_circular
                    && 
                    !$rlstat_max_reached
                ) {
                    # Push the TeX_lstat of the current iteration of $target_path into @TeX_lstat.
                    $TeX_lstat = TeX_lstat($target_path);
                    $target_TeX_path = TeX_escape($target_path);
                    $target_TeX_basename = path_to_TeXname($target_path);
                    $TeX_lstat .= "TeX-path={${target_TeX_path}}, TeX-basename={${target_TeX_basename}}";
                    $TeX_lstat = "{${TeX_lstat}}";
                    push(@TeX_lstat, $TeX_lstat);

                    $rlstat_max_reached = scalar(@link_targets_that_are_a_link) > $rlstat_opts;
                    # If $target_path is a symlink, continue with the next iteration. Otherwise, end the loop.
                    if (-l $target_path)
                    {
                        push(@link_targets_that_are_a_link, $target_path);
                        $target_path = link_destination($target_path);
                        # Source: https://stackoverflow.com/a/6475315/31298396
                        $link_is_circular = scalar( grep( /^$target_path$/, @link_targets_that_are_a_link ) );
                    }elsif ($link_is_circular)
                    { die("TeX_recurse_lstat: symlink is circular, but one of its intermediate targets is not a link.") }
                    else
                    { last; }
                }
                my $return = join(',', @TeX_lstat);
                $return = "targets={${return}}";
                if ($link_is_circular)
                { $return .= ", circular-link" }
                elsif ($rlstat_max_reached)
                { $return .= ", rlstat-maxed" }
                return($return)
            }else
            { return; }
        }else
        { die("TeX_recurse_lstat_ignore_first: there are $args != 1 arguments passed to me.") }
    }else
    { return "" }
}

my($in, $out) = rewrite_file("./textrees/textree_1");

my $TeXname;
my $TeXname_target;
my $link_target_type;
my $file_type;
my $dir_count = 0;
my $file_count = 0;
my $TeX_stat_string;
my $TeX_lstat_string;
my $TeX_rstat_string;
my %symlink_target_count_by_types = ( 
    'total'                   => 0,
    'nonexistent'             => 0,
    'dir'                     => 0, 
    'plain-file'              => 0, 
    'symlink'                 => 0, 
    'pipe'                    => 0, 
    'socket'                  => 0, 
    'block-special-file'      => 0, 
    'character-special-file'  => 0, 
    'tty'                     => 0
);
my %file_target_count_by_types = ( 
    'total'                   => 0,
    'non-symlinks'            => 0, 
    'plain-file'              => 0, 
    'pipe'                    => 0, 
    'socket'                  => 0, 
    'block-special-file'      => 0, 
    'character-special-file'  => 0, 
    'tty'                     => 0
);

# Read from $in, write to $out as normal.
while(my $line = <$in>) {
    # We later test the type of each file and symlink target. So, we need the correct name of the corresponding path. And for that, we need to convert some XML strings into the characters they actually represent. 
    $line =~ s/&quot;/"/g;
    $line =~ s/&amp;/&/g;
    $line =~ s/&lt;/</g;
    $line =~ s/&gt;/>/g;
    if ($line =~ m/( *)<directory name="(.*)">/)
    {
        $TeXname = path_to_TeXname(${2});
        $TeX_stat_string = TeX_stat(${2});
        $line = "${1}[{\\dirfmt[${TeX_stat_string}]{${TeXname}}}, dir\n";
    }
    elsif ($line =~ m/( *)<\/directory>/)
    {
        $line = "${1}]\n";
    }
    elsif ($line =~ m/( *)<file name="(.*)"><\/file>/)
    {
        $file_target_count_by_types{'non-symlinks'} = $file_target_count_by_types{'non-symlinks'} + 1;

        if (-f $2)
        {
            $file_type = "plain-file"
        }
        elsif (-p $2)
        {
            $file_type = "pipe"
        }
        elsif (-S $2)
        {
            $file_type = "socket"
        }
        elsif (-b $2)
        {
            $file_type = "block-special-file"
        }
        elsif (-c $2)
        {
            $file_type = "character-special-file"
        }
        elsif (-t $2)
        {
            $file_type = "tty"
        }
        elsif (-l $2)
        {
            die("file '$2' is actually a symlink, when tree says it is not?")
        }
        elsif (-d $2) 
        {
            die("file '$2' is actually a directory?")
        }
        elsif (!-e $2)
        {
            die("file '$2' is actually nonexistent?")
        }
        else
        {
            die("symlink target '$2' is not of any recognisable type")
        }
        $file_target_count_by_types{$file_type} = $file_target_count_by_types{$file_type} + 1;
        
        $TeXname = path_to_TeXname(${2});
        $TeX_stat_string = TeX_stat(${2});
        $line = "${1}[{\\filefmt[file-type={${file_type}}, ${TeX_stat_string}]{${TeXname}}}, file]\n";
    }
    elsif ($line =~ m/( *)<link name="(.*)" target="(.*)"><\/link>/)
    {
        $symlink_target_count_by_types{'total'} = $symlink_target_count_by_types{'total'} + 1;

        if (!-e $3)
        {
            $link_target_type = "nonexistent";
        }
        elsif (-d $3) 
        {
            $link_target_type = "dir";
        }
        elsif (-f $3)
        {
            $link_target_type = "plain-file"
        }
        elsif (-l $3)
        {
            $link_target_type = "symlink"
        }
        elsif (-p $3)
        {
            $link_target_type = "pipe"
        }
        elsif (-S $3)
        {
            $link_target_type = "socket"
        }
        elsif (-b $3)
        {
            $link_target_type = "block-special-file"
        }
        elsif (-c $3)
        {
            $link_target_type = "character-special-file"
        }
        elsif (-t $3)
        {
            $link_target_type = "tty"
        }
        else
        {
            die("symlink target '$3' is not of any recognisable type")
        }
        $symlink_target_count_by_types{$link_target_type} = $symlink_target_count_by_types{$link_target_type} + 1;

        $TeXname = path_to_TeXname(${2});
        $TeXname_target = path_to_TeXname(${3});
        $TeX_lstat_string = TeX_lstat(${2});
        $TeX_rstat_string = TeX_recurse_lstat_ignore_first(${2});
        $line = "${1}[{\\symlinkfmt[link-target-type=${link_target_type}, $TeX_lstat_string ${TeX_rstat_string}}]{${TeXname}}{${TeXname_target}}}, symlink]\n";
    }
    elsif ($line =~ m/<\?xml version=".*" encoding=".*"\?>|<report>|<\/report>/)
    {
        $line = "";
    }
    elsif ($line =~ m/<directories>([0-9]*)<\/directories>/)
    {
        $dir_count = $dir_count + 1;
        $line = "";
    }
    elsif ($line =~ m/<files>([0-9]*)<\/files>/)
    {
        $file_count = $file_count + 1;
        $line = "";
    }
    elsif ($line =~ m/<tree>/)
    {
        $line = "\\begin{forest}\n";
    }
    elsif ($line =~ m/<\/tree>/)
    {
        $line = "\\end{forest}\n";
    }
    else 
    {
        die("Error: a line is of an unexpected form: '$line'.")
    }
    print($out $line);
}

my $report_symlinks = "{\n";
for (keys %symlink_target_count_by_types){
    $report_symlinks .=
<<EOF
                ,$_ = $symlink_target_count_by_types{$_}
EOF
}
$report_symlinks .= "            }";

my $report_files = "{\n";
$file_target_count_by_types{'symlink'} = "$report_symlinks";
for (keys %file_target_count_by_types){
    $report_files .=
<<EOF
            ,$_ = $file_target_count_by_types{$_}
EOF
}
$report_files .= "        }";

print($out 
<<EOF
    \\report{
        ,dir  = $dir_count
        ,file = $report_files
    }
EOF
);