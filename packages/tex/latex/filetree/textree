# lstat the target of a symlink iteratively
    # Output: the TeX clist {{TeX_lstat{target_1}}},{TeX_lsat{target_2}},...}
    # There might be a trailing ", circular-link" or ", rlstat_maxed". 
sub TeX_recurse_lstat_ignore_first {
    # "ignore_first" as in the symlink itself is not lstat'ed
    my $args = scalar(@_);
    if ($args == 1)
    {
        my ($path) = @_;
        if (-l $path)
        {
            my $link_is_circular;
            my $rlstat_max_reached;
            my @link_targets_that_are_a_link;
            my $target_path = readlink($path);
            my @TeX_lstat;
            # Source: https://stackoverflow.com/a/6475315/31298396
            while ( 
                $link_is_circular
                && 
                $rlstat_max_reached
            ) {
                # Push the TeX_lstat of the current iteration of $target_path into @TeX_lstat.
                my $TeX_lstat = TeX_lstat($target_path);
                $TeX_lstat .= ", path={${target_path}}";
                $TeX_lstat = "{${TeX_lstat}}";
                push(@TeX_lstat, $TeX_lstat);

                $rlstat_max_reached = scalar(@link_targets_that_are_a_link) <= $rlstat_opts;
                # If $target_path is a symlink, continue with the next iteration. Otherwise, end the loop.
                if (-l $target_path)
                {
                    push(@link_targets_that_are_a_link, $target_path);
                    $target_path = readlink($target_path);
                    $link_is_circular = scalar( grep( /^$target_path$/, @link_targets_that_are_a_link ) );
                }elsif ($link_is_circular)
                { die("TeX_recurse_lstat: symlink is circular, but one of its intermediate targets is not a link.") }
                else
                { last; }
            }
            my $return = join(',', @TeX_lstat);
            $return = "targets={${return}}";
            if ($link_is_circular)
            { $return .= ", circular-link" }
            elsif ($rlstat_max_reached)
            { $return .= ", rlstat-maxed" }
            return($return)
        }else
        { return; }
    }else
    { die("TeX_recuse_lstat: there are $args != 1 arguments passed to me.") }
}

my($in, $out) = rewrite_file("./textrees/textree_1");

my $TeXname;
my $TeXname_target;
my $link_target_type;
my $file_type;
my $dir_count = 0;
my $file_count = 0;
my $TeX_stat_string;
my $TeX_lstat_string;
my %symlink_target_count_by_types = ( 
    'total'                   => 0,
    'nonexistent'             => 0,
    'dir'                     => 0, 
    'plain-file'              => 0, 
    'symlink'                 => 0, 
    'pipe'                    => 0, 
    'socket'                  => 0, 
    'block-special-file'      => 0, 
    'character-special-file'  => 0, 
    'tty'                     => 0
);
my %file_target_count_by_types = ( 
    'total'                   => 0,
    'non-symlinks'            => 0, 
    'plain-file'              => 0, 
    'pipe'                    => 0, 
    'socket'                  => 0, 
    'block-special-file'      => 0, 
    'character-special-file'  => 0, 
    'tty'                     => 0
);

# Read from $in, write to $out as normal.
while(my $line = <$in>) {
    # We later test the type of each file and symlink target. So, we need the correct name of the corresponding path. And for that, we need to convert some XML strings into the characters they actually represent. 
    $line =~ s/&quot;/"/g;
    $line =~ s/&amp;/&/g;
    $line =~ s/&lt;/</g;
    $line =~ s/&gt;/>/g;
    if ($line =~ m/( *)<directory name="(.*)">/)
    {
        $TeXname = path_to_TeXname(${2});
        $TeX_stat_string = TeX_stat(${2});
        $line = "${1}[{\\dirfmt[${TeX_stat_string}]{${TeXname}}}, dir\n";
    }
    elsif ($line =~ m/( *)<\/directory>/)
    {
        $line = "${1}]\n";
    }
    elsif ($line =~ m/( *)<file name="(.*)"><\/file>/)
    {
        $file_target_count_by_types{'non-symlinks'} = $file_target_count_by_types{'non-symlinks'} + 1;

        if (-f $2)
        {
            $file_type = "plain-file"
        }
        elsif (-p $2)
        {
            $file_type = "pipe"
        }
        elsif (-S $2)
        {
            $file_type = "socket"
        }
        elsif (-b $2)
        {
            $file_type = "block-special-file"
        }
        elsif (-c $2)
        {
            $file_type = "character-special-file"
        }
        elsif (-t $2)
        {
            $file_type = "tty"
        }
        elsif (-l $2)
        {
            die("file '$2' is actually a symlink, when tree says it is not?")
        }
        elsif (-d $2) 
        {
            die("file '$2' is actually a directory?")
        }
        elsif (!-e $2)
        {
            die("file '$2' is actually nonexistent?")
        }
        else
        {
            die("symlink target '$2' is not of any recognisable type")
        }
        $file_target_count_by_types{$file_type} = $file_target_count_by_types{$file_type} + 1;
        
        $TeXname = path_to_TeXname(${2});
        $TeX_stat_string = TeX_stat(${2});
        $line = "${1}[{\\filefmt[file-type={${file_type}}, ${TeX_stat_string}]{${TeXname}}}, file]\n";
    }
    elsif ($line =~ m/( *)<link name="(.*)" target="(.*)"><\/link>/)
    {
        $symlink_target_count_by_types{'total'} = $symlink_target_count_by_types{'total'} + 1;

        if (!-e $3)
        {
            $link_target_type = "nonexistent";
        }
        elsif (-d $3) 
        {
            $link_target_type = "dir";
        }
        elsif (-f $3)
        {
            $link_target_type = "plain-file"
        }
        elsif (-l $3)
        {
            $link_target_type = "symlink"
        }
        elsif (-p $3)
        {
            $link_target_type = "pipe"
        }
        elsif (-S $3)
        {
            $link_target_type = "socket"
        }
        elsif (-b $3)
        {
            $link_target_type = "block-special-file"
        }
        elsif (-c $3)
        {
            $link_target_type = "character-special-file"
        }
        elsif (-t $3)
        {
            $link_target_type = "tty"
        }
        else
        {
            die("symlink target '$3' is not of any recognisable type")
        }
        $symlink_target_count_by_types{$link_target_type} = $symlink_target_count_by_types{$link_target_type} + 1;

        $TeXname = path_to_TeXname(${2});
        $TeXname_target = path_to_TeXname(${3});
        $TeX_stat_string = TeX_stat(${2});
        $TeX_lstat_string = TeX_lstat(${2});
        $line = "${1}[{\\symlinkfmt[link-target={type=${link_target_type}, ${TeX_stat_string}}, $TeX_lstat_string]{${TeXname}}{${TeXname_target}}}, symlink]\n";
    }
    elsif ($line =~ m/<\?xml version=".*" encoding=".*"\?>|<report>|<\/report>/)
    {
        $line = "";
    }
    elsif ($line =~ m/<directories>([0-9]*)<\/directories>/)
    {
        $dir_count = $dir_count + 1;
        $line = "";
    }
    elsif ($line =~ m/<files>([0-9]*)<\/files>/)
    {
        $file_count = $file_count + 1;
        $line = "";
    }
    elsif ($line =~ m/<tree>/)
    {
        $line = "\\begin{forest}\n";
    }
    elsif ($line =~ m/<\/tree>/)
    {
        $line = "\\end{forest}\n";
    }
    else 
    {
        die("Error: a line is of an unexpected form: '$line'.")
    }
    print($out $line);
}

my $report_symlinks = "{\n";
for (keys %symlink_target_count_by_types){
    $report_symlinks .=
<<EOF
                ,$_ = $symlink_target_count_by_types{$_}
EOF
}
$report_symlinks .= "            }";

my $report_files = "{\n";
$file_target_count_by_types{'symlink'} = "$report_symlinks";
for (keys %file_target_count_by_types){
    $report_files .=
<<EOF
            ,$_ = $file_target_count_by_types{$_}
EOF
}
$report_files .= "        }";

print($out 
<<EOF
    \\report{
        ,dir  = $dir_count
        ,file = $report_files
    }
EOF
);